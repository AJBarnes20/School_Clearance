@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-students">0</div>
                <div class="stat-label">Total Students</div>
                <div style="font-size:11px;color:var(--muted);">Registered accounts</div>
            </div>
            <div class="stat-icon-wrap si-blue"><i class="fas fa-user-graduate"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-instructors">0</div>
                <div class="stat-label">Total Instructors</div>
                <div style="font-size:11px;color:var(--muted);">Registered accounts</div>
            </div>
            <div class="stat-icon-wrap si-green"><i class="fas fa-chalkboard-teacher"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-staff">0</div>
                <div class="stat-label">Total Staff</div>
                <div style="font-size:11px;color:var(--muted);">Registered accounts</div>
            </div>
            <div class="stat-icon-wrap si-orange"><i class="fas fa-briefcase"></i></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-num" id="stat-signatories">0</div>
                <div class="stat-label">Total Signatories</div>
                <div style="font-size:11px;color:var(--muted);">Assigned by admin</div>
            </div>
            <div class="stat-icon-wrap si-teal"><i class="fas fa-signature"></i></div>
        </div>
    </div>
</div>

<!-- ACCOUNTS REQUEST TABLE -->
<div class="panel">
    <div class="panel-hd">
        <span class="panel-hd-title" style="color:#4299e1;font-size:15px;">
            <i class="fas fa-user-clock me-2"></i>Account Registration Requests
        </span>
        <div class="search-wrap">
            <i class="fas fa-search"></i>
            <input type="text" class="search-input" placeholder="Search name, ID..." oninput="filterTable(this,'acc-table')" />
        </div>
    </div>

    <!-- Admin notice -->
    <div style="padding:10px 18px;background:rgba(66,153,225,0.06);border-bottom:1px solid rgba(66,153,225,0.15);font-size:12px;color:var(--muted);display:flex;align-items:flex-start;gap:8px;">
        <i class="fas fa-info-circle" style="color:#4299e1;margin-top:2px;flex-shrink:0;"></i>
        <span>
            Review each registration request and <strong style="color:var(--text);">assign a role</strong>
            (<strong style="color:var(--text);">Student</strong>, <strong style="color:var(--text);">Instructor</strong>, or <strong style="color:var(--text);">Staff</strong>)
            before approving. Approved users are granted access only after your confirmation.
        </span>
    </div>

    <div class="table-responsive">
        <table class="data-table" id="acc-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Student ID / Employee ID</th>
                    <th>Assign Role</th>
                    <th>Admin Action</th>
                </tr>
            </thead>
            <tbody id="acc-tbody"></tbody>
        </table>
    </div>

    <!-- Empty state -->
    <div id="acc-empty" style="padding:56px 24px;text-align:center;">
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(66,153,225,0.10);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
            <i class="fas fa-user-clock" style="font-size:30px;color:#4299e1;opacity:0.7;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">No Pending Requests</div>
        <div style="font-size:13px;color:var(--muted);max-width:400px;margin:0 auto;line-height:1.6;">
            Account registration requests will appear here. You can assign a role and approve or decline each one.
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     APPROVE CONFIRM MODAL
══════════════════════════════════════════ -->
<div id="approve-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:460px;margin:16px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(56,161,105,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="fas fa-user-check" style="font-size:22px;color:#38a169;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:6px;">Approve this account?</div>
        <div id="approve-name" style="font-size:13px;color:#4299e1;font-weight:700;margin-bottom:20px;"></div>

        <!-- Role assignment — 3 options -->
        <div style="text-align:left;margin-bottom:20px;">
            <label style="font-size:12px;font-weight:700;color:var(--text);display:block;margin-bottom:4px;">
                <i class="fas fa-user-tag me-1" style="color:#4299e1;"></i>Assign Role to User
            </label>
            <div style="font-size:11px;color:var(--muted);margin-bottom:10px;">
                Select the role this user will be granted upon approval.
            </div>
            <div style="display:flex;gap:10px;">
                <!-- Student -->
                <label id="role-student-label"
                    style="display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--border);border-radius:10px;cursor:pointer;flex:1;transition:all 0.2s;">
                    <input type="radio" name="confirm-role" value="Student" style="accent-color:#805ad5;width:14px;height:14px;" onchange="highlightRole()" />
                    <div>
                        <div style="font-size:12px;font-weight:700;color:var(--text);">
                            <i class="fas fa-user-graduate me-1" style="color:#805ad5;font-size:10px;"></i>Student
                        </div>
                        <div style="font-size:10px;color:var(--muted);">Clearance access</div>
                    </div>
                </label>
                <!-- Instructor -->
                <label id="role-instructor-label"
                    style="display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--border);border-radius:10px;cursor:pointer;flex:1;transition:all 0.2s;">
                    <input type="radio" name="confirm-role" value="Instructor" style="accent-color:#4299e1;width:14px;height:14px;" onchange="highlightRole()" />
                    <div>
                        <div style="font-size:12px;font-weight:700;color:var(--text);">
                            <i class="fas fa-chalkboard-teacher me-1" style="color:#4299e1;font-size:10px;"></i>Instructor
                        </div>
                        <div style="font-size:10px;color:var(--muted);">Signatory access</div>
                    </div>
                </label>
                <!-- Staff -->
                <label id="role-staff-label"
                    style="display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--border);border-radius:10px;cursor:pointer;flex:1;transition:all 0.2s;">
                    <input type="radio" name="confirm-role" value="Staff" style="accent-color:#ed8936;width:14px;height:14px;" onchange="highlightRole()" />
                    <div>
                        <div style="font-size:12px;font-weight:700;color:var(--text);">
                            <i class="fas fa-briefcase me-1" style="color:#ed8936;font-size:10px;"></i>Staff
                        </div>
                        <div style="font-size:10px;color:var(--muted);">Office access</div>
                    </div>
                </label>
            </div>

            <!-- No role selected warning -->
            <div id="no-role-warning"
                style="display:none;margin-top:10px;padding:8px 12px;background:rgba(229,62,62,0.1);border:1px solid rgba(229,62,62,0.3);border-radius:8px;font-size:11px;color:#fc8181;text-align:left;">
                <i class="fas fa-exclamation-circle me-1"></i>Please select a role before approving.
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3">
            <button onclick="closeApprove()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="confirmApprove()"
                style="background:#38a169;border:none;color:white;border-radius:8px;padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-check me-1"></i>Approve &amp; Assign Role
            </button>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     DECLINE CONFIRM MODAL
══════════════════════════════════════════ -->
<div id="decline-modal"
    style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:400px;margin:16px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(229,62,62,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="fas fa-user-times" style="font-size:22px;color:#fc8181;"></i>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:6px;">Decline this request?</div>
        <div id="decline-name" style="font-size:13px;color:#fc8181;font-weight:700;margin-bottom:4px;"></div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:24px;">
            The user will be notified that their registration was not approved.
            This action cannot be undone.
        </div>
        <div class="d-flex justify-content-center gap-3">
            <button onclick="closeDecline()"
                style="background:rgba(255,255,255,0.07);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 22px;font-size:13px;cursor:pointer;">
                Cancel
            </button>
            <button onclick="confirmDecline()"
                style="background:#e53e3e;border:none;color:white;border-radius:8px;padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;">
                <i class="fas fa-times me-1"></i>Decline
            </button>
        </div>
    </div>
</div>

@section Styles {
<style>
    .btn-approve {
        background: #38a169; color: #fff; border: none; border-radius: 6px;
        padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; transition: background 0.2s;
    }
    .btn-approve:hover { background: #2f855a; }

    .btn-decline {
        background: #e53e3e; color: #fff; border: none; border-radius: 6px;
        padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; transition: background 0.2s;
    }
    .btn-decline:hover { background: #c53030; }

    .role-select-inline {
        background: var(--card); border: 1px solid var(--border); border-radius: 6px;
        padding: 5px 8px; font-size: 12px; color: var(--text);
        cursor: pointer; outline: none; transition: border-color 0.2s;
    }
    .role-select-inline:focus { border-color: #4299e1; }

    .si-orange { background: rgba(237,137,54,0.15); color: #ed8936; }
</style>
}

@section Scripts {
<script>
    const ROLES = {
        Student:    { label:'Student',    color:'#805ad5', bg:'rgba(128,90,213,0.15)', emoji:'🎓' },
        Instructor: { label:'Instructor', color:'#4299e1', bg:'rgba(66,153,225,0.15)', emoji:'📋' },
        Staff:      { label:'Staff',      color:'#ed8936', bg:'rgba(237,137,54,0.15)', emoji:'🗂️' }
    };

    let requests     = [];
    let actionIndex  = null;
    let activePeriod = null;

    // ── Load stats from DB ────────────────────────────
    async function loadStats() {
        try {
            const res  = await fetch('/api/admin/stats');
            const data = await res.json();
            document.getElementById('stat-students').textContent    = data.students    ?? 0;
            document.getElementById('stat-instructors').textContent = data.instructors ?? 0;
            document.getElementById('stat-staff').textContent       = data.staff       ?? 0;
            document.getElementById('stat-signatories').textContent = data.signatories ?? 0;
        } catch { }
    }

    // ── Load active period ────────────────────────────
    async function loadPeriod() {
        try {
            const res  = await fetch('/api/admin/active-period');
            const data = await res.json();
            if (data.ay) {
                activePeriod = data;
                document.getElementById('period-ay').textContent      = `A.Y. ${data.ay},`;
                document.getElementById('period-sem').textContent     = data.sem;
                document.getElementById('period-badge').style.display = '';
            } else {
                document.getElementById('period-ay').textContent      = 'No Active Period';
                document.getElementById('period-sem').textContent     = 'Set one in Academic Management';
                document.getElementById('period-badge').style.display = 'none';
            }
        } catch { }
    }

    // ── Load pending users ────────────────────────────
    async function loadRequests() {
        try {
            const res  = await fetch('/api/admin/pending-users');
            const data = await res.json();
            requests = data.map(u => ({
                id:           u.id,
                name:         u.name,
                idNumber:     u.idNumber,
                status:       'pending',
                assignedRole: null
            }));
            renderRequests();
        } catch { renderRequests(); }
    }

    function renderRequests() {
        const tbody = document.getElementById('acc-tbody');
        const empty = document.getElementById('acc-empty');
        tbody.innerHTML = '';
        const pending = requests.filter(r => r.status === 'pending');
        if (pending.length === 0) { empty.style.display = 'block'; return; }
        empty.style.display = 'none';
        let rowNum = 1;
        requests.forEach((r, i) => {
            if (r.status !== 'pending') return;
            const options = Object.entries(ROLES).map(([key, c]) =>
                `<option value="${key}">${c.emoji} ${c.label}</option>`).join('');
            const tr = document.createElement('tr');
            tr.dataset.index = i;
            tr.innerHTML = `
                <td style="color:var(--muted);">${String(rowNum++).padStart(2,'0')}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="user-avatar-sm" style="background:#4299e1;">${escHtml(r.name.charAt(0))}</div>
                        ${escHtml(r.name)}
                    </div>
                </td>
                <td style="color:var(--muted);">${escHtml(r.idNumber)}</td>
                <td>
                    <select class="role-select-inline" id="inline-role-${i}">
                        <option value="" disabled selected>— Select role —</option>
                        ${options}
                    </select>
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <button class="btn-approve" onclick="openApprove(${i})"><i class="fas fa-check me-1"></i>Approve</button>
                        <button class="btn-decline" onclick="openDecline(${i})"><i class="fas fa-times me-1"></i>Decline</button>
                    </div>
                </td>`;
            tbody.appendChild(tr);
        });
    }

    function openApprove(index) {
        actionIndex = index;
        document.getElementById('approve-name').textContent = requests[index].name;
        document.getElementById('no-role-warning').style.display = 'none';
        const inlineVal = document.getElementById(`inline-role-${index}`)?.value;
        document.querySelectorAll('input[name="confirm-role"]').forEach(radio => {
            radio.checked = inlineVal ? radio.value === inlineVal : false;
        });
        highlightRole();
        document.getElementById('approve-modal').style.display = 'flex';
    }

    function closeApprove() {
        document.getElementById('approve-modal').style.display = 'none';
        actionIndex = null;
    }

    async function confirmApprove() {
        const selected = document.querySelector('input[name="confirm-role"]:checked');
        if (!selected) { document.getElementById('no-role-warning').style.display = 'block'; return; }
        const r = requests[actionIndex];
        try {
            const res = await fetch('/api/admin/approve-user', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: r.id, role: selected.value })
            });
            const data = await res.json();
            if (data.success) {
                r.status       = 'approved';
                r.assignedRole = selected.value;
            }
        } catch { }
        closeApprove();
        renderRequests();
        loadStats();
    }

    function openDecline(index) {
        actionIndex = index;
        document.getElementById('decline-name').textContent = requests[index].name;
        document.getElementById('decline-modal').style.display = 'flex';
    }

    function closeDecline() {
        document.getElementById('decline-modal').style.display = 'none';
        actionIndex = null;
    }

    async function confirmDecline() {
        const r = requests[actionIndex];
        try {
            await fetch('/api/admin/decline-user', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: r.id })
            });
        } catch { }
        requests.splice(actionIndex, 1);
        closeDecline();
        renderRequests();
    }

    function highlightRole() {
        const val = document.querySelector('input[name="confirm-role"]:checked')?.value;
        ['role-student-label','role-instructor-label','role-staff-label'].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.style.borderColor = 'var(--border)'; el.style.background = 'transparent'; }
        });
        if (val && ROLES[val]) {
            const el = document.getElementById(`role-${val.toLowerCase()}-label`);
            if (el) { el.style.borderColor = ROLES[val].color; el.style.background = ROLES[val].bg; }
        }
        if (val) document.getElementById('no-role-warning').style.display = 'none';
    }

    document.getElementById('approve-modal').addEventListener('click', function(e) { if (e.target===this) closeApprove(); });
    document.getElementById('decline-modal').addEventListener('click', function(e) { if (e.target===this) closeDecline(); });

    function filterTable(input, tableId) {
        const q = input.value.toLowerCase();
        document.querySelectorAll('#'+tableId+' tbody tr').forEach(r =>
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'
        );
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Init ─────────────────────────────────────────
    loadStats();
    loadPeriod();
    loadRequests();
</script>
}