//  INSTRUCTOR DETAIL
// ══════════════════════════════════════════════════════════════════════════════
async function viewDetail(id) {
    document.getElementById('detail-panel').style.display  = 'block';
    document.getElementById('det-error').style.display     = 'none';
    document.getElementById('det-header-name').textContent = 'Loading...';
    document.getElementById('det-name').textContent        = 'Loading...';
    document.getElementById('det-avatar').textContent      = '?';
    ['det-first','det-last','det-eid'].forEach(fid => {
        const el = document.getElementById(fid); if (el) el.value = '';
    });
    document.getElementById('det-positions').innerHTML = '';
    setTimeout(() => document.getElementById('detail-panel')
        .scrollIntoView({ behavior:'smooth', block:'start' }), 50);

    try {
        const res  = await fetch(`/api/admin/instructors/${id}`);
        const data = await res.json();
        if (data.error) {
            document.getElementById('det-error').style.display     = 'block';
            document.getElementById('det-error-msg').textContent   = data.error;
            document.getElementById('det-header-name').textContent = 'Error';
            document.getElementById('det-name').textContent        = 'Error';
            return;
        }
        const fullName = [data.firstName, data.lastName].filter(x => x && x !== '—').join(' ');
        document.getElementById('det-header-name').textContent = fullName || '—';
        document.getElementById('det-avatar').textContent      = data.firstName?.charAt(0) ?? '?';
        document.getElementById('det-name').textContent        = fullName || '—';
        document.getElementById('det-eid-label').textContent   = `Employee ID: ${data.employeeId ?? '—'}`;
        document.getElementById('det-first').value             = data.firstName  ?? '—';
        document.getElementById('det-last').value              = data.lastName   ?? '—';
        document.getElementById('det-eid').value               = data.employeeId ?? '—';

        const posDiv    = document.getElementById('det-positions');
        const positions = Array.isArray(data.positions) ? data.positions : [];
        posDiv.innerHTML = positions.length
            ? positions.map(p => `<span style="${badgeStyle('#4299e1','rgba(66,153,225,0.15)')};font-size:11px;">${escHtml(p)}</span>`).join('')
            : `<span style="font-size:12px;color:var(--muted);">No positions assigned</span>`;
    } catch (e) {
        document.getElementById('det-error').style.display     = 'block';
        document.getElementById('det-error-msg').textContent   = e.message;
        document.getElementById('det-header-name').textContent = 'Error';
    }
}

function closeDetail() { document.getElementById('detail-panel').style.display = 'none'; }

