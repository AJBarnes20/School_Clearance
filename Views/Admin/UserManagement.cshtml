function renderOrgOfficers() {
    const tbody = document.getElementById('all-org-tbody');
    const empty = document.getElementById('all-org-empty');
    tbody.innerHTML = '';

    // Use dedicated API result; fall back to merging existing loaded arrays
    let positions = allOrgPositions;
    if (!positions.length) {
        positions = [
            ...stuSignatories.map(s => ({
                source: 'sig', id: s.id, userId: s.userId ?? 0,
                name: s.name, role: 'Student', idNum: s.idNum ?? '—',
                posTitle: s.position ?? '—', courseCode: '', yearLevel: 0, section: ''
            })),
            ...orgSignatories.map(s => ({
                source: 'org', id: s.id, userId: s.userId ?? 0,
                name: s.name, role: 'Instructor', idNum: s.eid ?? '—',
                posTitle: s.pos ?? '—', courseCode: s.courseCode ?? '',
                yearLevel: s.yearLevel ?? 0, section: s.section ?? ''
            }))
        ];
    }

    if (!positions.length) {
        empty.style.display = 'block'; return;
    }
    empty.style.display = 'none';

    const roleColor = { Student:'#9f7aea', Instructor:'#4299e1', Staff:'#0d9488', Admin:'#ed8936' };

    positions.forEach((p, i) => {
        const rc = roleColor[p.role] ?? '#718096';
        const advSection = p.posTitle === 'Class Adviser' && p.courseCode
            ? `${p.courseCode} – ${p.yearLevel}${p.section ? ', Sec ' + p.section : ''}`
            : '—';
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar-sm" style="background:${rc};">${escHtml(p.name.charAt(0))}</div>
                    <span style="font-weight:600;font-size:13px;">${escHtml(p.name)}</span>
                </div>
            </td>
            <td><span style="${badgeStyle(rc, rc + '22')}">${escHtml(p.role)}</span></td>
            <td style="color:var(--muted);font-size:12px;">${escHtml(p.idNum)}</td>
            <td><span style="${badgeStyle('#38a169','rgba(56,161,105,0.15)')}">${escHtml(p.posTitle)}</span></td>
            <td style="font-size:12px;color:var(--muted);">${escHtml(advSection)}</td>
            <td style="text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;">
                    <button onclick="openViewOrgModal('${escHtml(p.posTitle).replace(/'/g,"\\'")}', '${escHtml(p.name).replace(/'/g,"\\'")}', '${escHtml(advSection).replace(/'/g,"\\'")}' )"
                            style="${btnStyle('#4299e1','rgba(66,153,225,0.12)')}">
                        <i class="fas fa-eye me-1"></i>View
                    </button>
                    <button onclick="removeOrgPosition('${p.source}', ${p.id})"
                            style="${btnStyle('#e53e3e','rgba(229,62,62,0.12)')}">
                        <i class="fas fa-trash-alt me-1"></i>Remove
                    </button>
                </div>
            </td>`;
        tbody.appendChild(tr);
    });
}

async function removeOrgPosition(source, id) {
    if (!confirm('Remove this position assignment?')) return;
    const url = source === 'sig'
        ? `/api/admin/student-signatories/${id}`
        : `/api/admin/org-signatories/${id}`;
    try {
        await fetch(url, { method: 'DELETE' });
        await loadAllOrgPositions();
        renderOrgOfficers();
    } catch (e) { alert('Error: ' + e.message); }
}

