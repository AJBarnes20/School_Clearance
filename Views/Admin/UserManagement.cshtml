    document.getElementById('ao-error').style.display        = 'none';
    populateAoCaCourses();
    document.getElementById('assign-org-overlay').style.display = 'block';
    document.getElementById('assign-org-modal').style.display   = 'flex';
    document.getElementById('assign-org-modal').style.flexDirection = 'column';
}
function closeAssignOrgModal() {
    document.getElementById('assign-org-overlay').style.display = 'none';
    document.getElementById('assign-org-modal').style.display   = 'none';
}

function filterAoDD(val) {
    const dd  = document.getElementById('ao-dropdown');
    const q   = val.trim().toLowerCase();
    const matches = allUsers.filter(u =>
        u.name.toLowerCase().includes(q) || u.idNum.toLowerCase().includes(q)
    ).slice(0, 12);

    if (!q || !matches.length) { dd.style.display = 'none'; return; }

    dd.innerHTML = matches.map(u => `
        <div onclick="selectAoUser(${u.id})"
             style="padding:10px 14px;cursor:pointer;display:flex;align-items:center;gap:10px;
                    border-bottom:1px solid var(--border);transition:background 0.12s;"
             onmouseover="this.style.background='rgba(56,161,105,0.08)'"
             onmouseout="this.style.background=''">
            <div class="user-avatar-sm" style="background:#38a169;flex-shrink:0;">${escHtml(u.name.charAt(0))}</div>
            <div>
                <div style="font-size:13px;font-weight:600;color:var(--text);">${escHtml(u.name)}</div>
                <div style="font-size:11px;color:var(--muted);">${escHtml(u.role)} · ${escHtml(u.idNum)}</div>
            </div>
        </div>`).join('');
    dd.style.display = 'block';
}
function selectAoUser(id) {
    const u = allUsers.find(x => x.id === id);
    if (!u) return;
    aoSelectedUser = u;
    document.getElementById('ao-search').value = u.name;
    document.getElementById('ao-dropdown').style.display = 'none';
    document.getElementById('ao-pill-av').textContent    = u.name.charAt(0);
    document.getElementById('ao-pill-name').textContent  = u.name;
    document.getElementById('ao-pill-meta').textContent  = `${u.role} · ${u.idNum}`;
    document.getElementById('ao-pill').style.display     = 'flex';
}
function clearAoSelection() {
    aoSelectedUser = null;
    document.getElementById('ao-search').value = '';
    document.getElementById('ao-pill').style.display = 'none';
}

function onAoPosChange(val) {
    document.getElementById('ao-custom-wrap').style.display  = val === '__custom__' ? '' : 'none';
    document.getElementById('ao-adviser-wrap').style.display = val === 'Class Adviser' ? '' : 'none';
}

function populateAoCaCourses() {
    const sel = document.getElementById('ao-ca-course');
    const courses = [...new Set(curriculums.map(c => c.courseCode).filter(Boolean))].sort();
    sel.innerHTML = '<option value="" disabled selected>— Select Course —</option>' +
        courses.map(c => `<option value="${escHtml(c)}">${escHtml(c)}</option>`).join('');
    document.getElementById('ao-ca-year').innerHTML    = '<option value="" disabled selected>— Year —</option>';
    document.getElementById('ao-ca-section').innerHTML = '<option value="" disabled selected>— Section —</option>';
}
function aoFilterYear() {
    const course = document.getElementById('ao-ca-course').value;
    const years  = [...new Set(curriculums.filter(c => c.courseCode === course).map(c => c.yearLevel))].sort();
    const sel    = document.getElementById('ao-ca-year');
    sel.innerHTML = '<option value="" disabled selected>— Year —</option>' +
        years.map(y => {
            const label = y === 1 ? '1st Year' : y === 2 ? '2nd Year' : y === 3 ? '3rd Year' : `${y}th Year`;
            return `<option value="${y}">${label}</option>`;
        }).join('');
    document.getElementById('ao-ca-section').innerHTML = '<option value="" disabled selected>— Section —</option>';
}
function aoFilterSection() {
    const course = document.getElementById('ao-ca-course').value;
    const year   = parseInt(document.getElementById('ao-ca-year').value);
    const sections = curriculums.filter(c => c.courseCode === course && c.yearLevel === year)
                                .map(c => c.section).filter(Boolean).sort();
    const sel = document.getElementById('ao-ca-section');
    sel.innerHTML = '<option value="" disabled selected>— Section —</option>' +
        sections.map(s => `<option value="${escHtml(s)}">${escHtml(s)}</option>`).join('');
}

async function submitAssignOrg() {
    const errEl = document.getElementById('ao-error');
    errEl.style.display = 'none';

    if (!aoSelectedUser) { errEl.textContent = 'Please select a user.'; errEl.style.display = ''; return; }

    const posSelect = document.getElementById('ao-pos').value;
    if (!posSelect)   { errEl.textContent = 'Please select a position.'; errEl.style.display = ''; return; }

    const posTitle = posSelect === '__custom__'
        ? document.getElementById('ao-custom').value.trim()
        : posSelect;
    if (!posTitle) { errEl.textContent = 'Please enter a custom position title.'; errEl.style.display = ''; return; }

    const btn = document.getElementById('ao-submit-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving…';

    try {
        let res, data;
        if (posTitle === 'Class Adviser') {
            const course   = document.getElementById('ao-ca-course').value;
            const yearLevel= parseInt(document.getElementById('ao-ca-year').value);
            const section  = document.getElementById('ao-ca-section').value;
            if (!course || !yearLevel || !section) {
                errEl.textContent = 'Please select course, year level, and section for Class Adviser.';
                errEl.style.display = ''; btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check me-1"></i>Assign'; return;
            }
            const cur = curriculums.find(c => c.courseCode === course && c.yearLevel === yearLevel && c.section === section);
            if (!cur) {
                errEl.textContent = 'Section not found in curriculum. Please add the curriculum first.';
                errEl.style.display = ''; btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check me-1"></i>Assign'; return;
            }
            res  = await fetch('/api/admin/org-signatories', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: aoSelectedUser.id, pos: 'Class Adviser', curriculumId: cur.id })
            });
            data = await res.json();
        } else if (aoSelectedUser.role === 'Student') {
            // Student non-adviser positions → user_signatures (self-approval)
            res  = await fetch('/api/admin/student-signatories', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: aoSelectedUser.id, position: posTitle })
            });
            data = await res.json();
        } else {
            // Instructor / Staff / Admin → organizations
            res  = await fetch('/api/admin/org-signatories', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: aoSelectedUser.id, pos: posTitle })
            });
            data = await res.json();
        }

        if (data.success) {
            closeAssignOrgModal();
            await loadAllOrgPositions();
            await loadStuSignatories();
            await loadOrgSignatories();
            renderOrgOfficers();
        } else {
            errEl.textContent = data.error || 'Failed to assign.';
            errEl.style.display = '';
        }
    } catch (e) {
        errEl.textContent = 'Error: ' + e.message;
        errEl.style.display = '';
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-check me-1"></i>Assign';
}

// ── VIEW CLEARANCE REQUESTS MODAL ───────────────────────────────────────────
async function openViewOrgModal(posTitle, personName, sectionLabel) {
    viewOrgCurrentPos = posTitle;
    viewOrgCurrentPid = 0;

    document.getElementById('view-org-title').textContent = `${posTitle} — ${personName}`;
    document.getElementById('view-org-overlay').style.display = 'block';
    document.getElementById('view-org-modal').style.display   = 'block';

    // Build period filter pills
    const pillBox = document.getElementById('view-period-pills');
    pillBox.innerHTML = '';
    const allPill = document.createElement('button');
    allPill.textContent = 'All Periods';
    allPill.dataset.pid = '0';
    allPill.className   = 'period-pill active';
    allPill.onclick = () => selectViewPeriod(0, posTitle);
    pillBox.appendChild(allPill);

    allPeriodsList.forEach(p => {
        const btn     = document.createElement('button');
        btn.textContent = `A.Y. ${p.ay}, ${p.sem}`;
        btn.dataset.pid = p.id;
        btn.className   = 'period-pill' + (p.status === 'Active' ? ' pill-active' : '');
        btn.onclick = () => selectViewPeriod(p.id, posTitle);
        pillBox.appendChild(btn);
    });

    await loadOrgClearanceData(posTitle, 0);
}
function closeViewOrgModal() {
    document.getElementById('view-org-overlay').style.display = 'none';
    document.getElementById('view-org-modal').style.display   = 'none';
}

function selectViewPeriod(pid, posTitle) {
    viewOrgCurrentPid = pid;
    document.querySelectorAll('.period-pill').forEach(b =>
        b.classList.toggle('active', parseInt(b.dataset.pid) === pid));
    loadOrgClearanceData(posTitle || viewOrgCurrentPos, pid);
}

async function loadOrgClearanceData(posTitle, pid) {
    const body = document.getElementById('view-org-body');
    body.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;"><i class="fas fa-spinner fa-spin" style="font-size:20px;display:block;margin-bottom:10px;"></i>Loading…</div>';

    try {
        const url = `/api/admin/org-clearance?position=${encodeURIComponent(posTitle)}&periodId=${pid}`;
        const r   = await fetch(url);
        const data = await r.json();

        if (!Array.isArray(data) || !data.length) {
            body.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;">
                <i class="fas fa-inbox" style="font-size:28px;opacity:0.3;display:block;margin-bottom:10px;"></i>
                No clearance requests found for this period.</div>`;
            return;
        }

        const statusColor = { Pending:'#f6ad55', Cleared:'#68d391', Declined:'#fc8181' };
        body.innerHTML = `
            <div class="table-responsive">
                <table class="data-table">
                    <thead><tr>
                        <th>#</th>
                        <th>Student Name</th>
                        <th>Student No.</th>
                        <th>Period</th>
                        <th style="text-align:center;">Status</th>
                        <th>Date Requested</th>
                    </tr></thead>
                    <tbody>${data.map((row, i) => {
                        const sc = statusColor[row.status] ?? '#718096';
                        return `<tr>
                            <td style="color:var(--muted);">${String(i+1).padStart(2,'0')}</td>
                            <td style="font-weight:600;">${escHtml(row.studentName)}</td>
                            <td style="color:var(--muted);font-size:12px;">${escHtml(row.studentNumber)}</td>
                            <td style="font-size:12px;">${escHtml(row.periodLabel)}</td>
                            <td style="text-align:center;">
                                <span style="${badgeStyle(sc, sc + '33')}">${escHtml(row.status)}</span>
                            </td>
                            <td style="font-size:12px;color:var(--muted);">${escHtml(row.createdAt)}</td>
                        </tr>`;
                    }).join('')}</tbody>
                </table>
            </div>`;
    } catch (e) {
        body.innerHTML = `<div style="text-align:center;padding:40px;color:#fc8181;font-size:13px;">
            Error loading data: ${escHtml(e.message)}</div>`;
    }
}

