@model OnlineClearanceSystem.Models.StudentDashboardViewModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<style>
    .check-box { width: 22px; height: 22px; border-radius: 50%; border: 2px solid #ccc; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s; background: white; }
    .check-box i { display: none; font-size: 12px; }
    .check-box.active { background: var(--green); border-color: var(--green); }
    .check-box.active i { display: block; color: white; }

    /* ── STAT ROW ── */
    .stat-row {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
        align-items: stretch;
    }

    /* ── STAT CARD ── */
    .stat-card {
        flex: 1 1 0;
        border-radius: 12px;
        padding: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: none;
        min-width: 0;
        min-height: 100px;
    }
    .stat-card.green-card  { background: linear-gradient(135deg, #1e7a46, #28a745); }
    .stat-card.orange-card { background: linear-gradient(135deg, #b8560a, #e07b2a); }
    .stat-card.blue-card   { background: linear-gradient(135deg, #1a5fa8, #3182ce); }

    .stat-num   { font-size: 28px; font-weight: 800; color: #ffffff; line-height: 1; }
    .stat-label { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.9); margin-top: 3px; }
    .stat-sub   { font-size: 11px; color: rgba(255,255,255,0.65); margin-top: 2px; }

    .stat-icon-wrap {
        width: 48px; height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        color: white;
        flex-shrink: 0;
    }

    /* ── ANNOUNCEMENT TABS ── */
    .ann-tab {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.18s, color 0.18s;
        letter-spacing: 0.4px;
        background: #ffffff;
        color: #111;
        border: 2px solid transparent;
    }

    /* Default (unselected) — white bg, black text, colored border */
    .ann-tab.tab-all     { border-color: #28a745; }
    .ann-tab.tab-urgent  { border-color: #dc3545; }
    .ann-tab.tab-pinned  { border-color: #0d6efd; }
    .ann-tab.tab-events  { border-color: #1a4731; }
    .ann-tab.tab-general { border-color: #d4a017; }

    /* Active (selected) — filled bg, white text */
    .ann-tab.tab-all.active     { background: #28a745; color: #fff; border-color: #28a745; }
    .ann-tab.tab-urgent.active  { background: #dc3545; color: #fff; border-color: #dc3545; }
    .ann-tab.tab-pinned.active  { background: #0d6efd; color: #fff; border-color: #0d6efd; }
    .ann-tab.tab-events.active  { background: #1a4731; color: #fff; border-color: #1a4731; }
    .ann-tab.tab-general.active { background: #d4a017; color: #fff; border-color: #d4a017; }

    /* ── ANNOUNCEMENT PANEL HEADER ── */
    .ann-panel-header {
        background: var(--green, #28a745);
        color: white;
        padding: 13px 18px;
        border-radius: 12px 12px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        font-size: 14px;
    }

    /* ── ANNOUNCEMENT PANEL BODY ── */
    .ann-panel-body {
        background: white;
        border-radius: 0 0 12px 12px;
        padding: 16px 18px 18px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }
</style>

<!-- ── STAT ROW (3 cards only, period card removed) ── -->
<div class="col-lg-8">
    <div class="stat-row">

        <!-- SUBJECT CLEARED -->
        <div class="stat-card green-card">
            <div>
                <div class="stat-num">@(Model?.SubjectCleared ?? 0)</div>
                <div class="stat-label">Subject Cleared</div>
                <div class="stat-sub">Total Subjects</div>
            </div>
            <div class="stat-icon-wrap">
                <i class="fas fa-clipboard-check"></i>
            </div>
        </div>

        <!-- SUBJECT PENDING -->
        <div class="stat-card orange-card">
            <div>
                <div class="stat-num">@(Model?.SubjectIncomplete ?? 0)</div>
                <div class="stat-label">Subject Pending</div>
            </div>
            <div class="stat-icon-wrap">
                <i class="fas fa-clock"></i>
            </div>
        </div>

        <!-- ORGANIZATION CLEARED -->
        <div class="stat-card blue-card">
            <div>
                <div class="stat-num">@(Model?.OrgCleared ?? 0)</div>
                <div class="stat-label">Organization Cleared</div>
            </div>
            <div class="stat-icon-wrap">
                <i class="fas fa-sitemap"></i>
            </div>
        </div>

    </div>
</div>

    <!-- ── CHECKLIST + ANNOUNCEMENTS ── -->
<div class="row g-3">

    <!-- CHECKLIST -->
    <div class="col-md-5">
        <div class="page-card">
            <div style="background:var(--green);color:white;padding:13px 18px;
                        display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:700;font-size:14px;">
                    <i class="fas fa-tasks me-2"></i>Clearance Checklist
                </span>
                <span id="progress-badge"
                      style="background:var(--green-accent);border-radius:20px;
                             padding:3px 12px;font-size:11px;font-weight:700;">
                    0/5 Completed
                </span>
            </div>
            @foreach (var step in new[] {
                new { title="Step 1: Select Enrolled Subjects",
                      desc="Select the subjects you enrolled." },
                new { title="Step 2: Confirm Enrolled Subjects",
                      desc="Confirm your selected enrolled subjects, then submit to the assigned Instructor." },
                new { title="Step 3: Subject Instructor's Approval",
                      desc="Wait for your Subject Instructors to sign your clearance." },
                new { title="Step 4: Final Approval",
                      desc="Lastly, get approval from the Organization's Signatories." },
                new { title="Final Check",
                      desc="Download and print the PDF. Make sure all of the above are approved to proceed." },
            })
            {
                <div class="checklist-item">
                    <div class="check-box"><i class="fas fa-check"></i></div>
                    <div>
                        <div class="check-title">@step.title</div>
                        <div class="check-desc">@step.desc</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ANNOUNCEMENTS -->
    <div class="col-md-7">
        <div class="ann-panel-header">
            <span><i class="fas fa-bullhorn me-2"></i>Announcements</span>
        </div>
        <div class="ann-panel-body">

            <!-- FILTER TABS -->
            <div class="d-flex gap-2 mb-3 flex-wrap">
                <button class="ann-tab tab-all active"    onclick="filterAnn('all',this)">ALL</button>
                <button class="ann-tab tab-urgent"        onclick="filterAnn('Urgent',this)">URGENT</button>
                <button class="ann-tab tab-pinned"        onclick="filterAnn('Pinned',this)">
                    <i class="fas fa-thumbtack me-1"></i>PINNED
                </button>
                <button class="ann-tab tab-events"        onclick="filterAnn('Event',this)">EVENTS</button>
                <button class="ann-tab tab-general"       onclick="filterAnn('General',this)">GENERAL</button>
            </div>

            <!-- ANNOUNCEMENT LIST -->
            <div id="ann-list">
                @if (Model?.Announcements != null && Model.Announcements.Any())
                {
                    @foreach (var ann in Model.Announcements)
                    {
                        <div class="ann-card" data-tag="@ann.Type.ToLower()">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="ann-avatar">SA</div>
                                    <div>
                                        <div style="font-weight:700;font-size:12px;">System Administrator</div>
                                        <div style="font-size:11px;color:#888;">@ann.Date</div>
                                    </div>
                                </div>
                                <div class="d-flex gap-1">
                                    @if (ann.Type == "Pinned")
                                    {
                                        <span class="ann-tag tag-pinned">
                                            <i class="fas fa-thumbtack me-1"></i>Pinned
                                        </span>
                                    }
                                    @if (ann.Type == "Urgent")
                                    {
                                        <span class="ann-tag tag-urgent">Urgent</span>
                                    }
                                    @if (ann.Type == "Event")
                                    {
                                        <span class="ann-tag tag-event">Event</span>
                                    }
                                    @if (ann.Type == "General" || string.IsNullOrEmpty(ann.Type))
                                    {
                                        <span class="ann-tag" style="background:#f3f4f6;color:#555;">General</span>
                                    }
                                </div>
                            </div>
                            <div style="font-weight:700;font-size:13px;margin-bottom:6px;">@ann.Title</div>
                            <div style="font-size:12px;color:#555;line-height:1.6;">@ann.Content</div>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:40px 24px;color:#888;">
                        <i class="fas fa-bullhorn"
                           style="font-size:32px;color:#ddd;margin-bottom:12px;display:block;"></i>
                        <div style="font-size:14px;font-weight:600;color:#aaa;">No announcements yet</div>
                        <div style="font-size:12px;margin-top:4px;">
                            Check back later for updates from the Admin.
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterAnn(tag, btn) {
        // Remove active from all tabs
        document.querySelectorAll('.ann-tab').forEach(b => b.classList.remove('active'));
        // Set active on clicked tab
        btn.classList.add('active');
        // Show/hide announcement cards
        document.querySelectorAll('#ann-list .ann-card').forEach(c => {
            c.style.display = tag === 'all'
                ? ''
                : (c.dataset.tag || '').toLowerCase()
                    .includes(tag.toLowerCase()) ? '' : 'none';
        });
    }

    document.querySelectorAll('.check-box').forEach(box => {
        box.addEventListener('click', () => {
            box.classList.toggle('active');
            const total   = document.querySelectorAll('.check-box').length;
            const checked = document.querySelectorAll('.check-box.active').length;
            document.getElementById('progress-badge').textContent =
                `${checked}/${total} Completed`;
        });
    });
</script>
}
