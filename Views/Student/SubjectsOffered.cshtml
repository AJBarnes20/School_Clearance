@model OnlineClearanceSystem.Models.SubjectOfferedViewModel

@{
    ViewData["Title"]      = "Subjects Offered";
    ViewData["ActivePage"] = "SubjectsOffered";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    bool showConfirm = ViewData["ShowConfirm"] is true;
}

<style>
    /* ── PERIOD SELECTOR ── */
    .period-selector-wrap { position:relative; display:inline-block; }

    .period-btn {
        display:flex; align-items:center; gap:10px;
        background:linear-gradient(135deg,#1a4731,#2d6a4f);
        border:none; border-radius:10px; padding:9px 16px;
        cursor:pointer; transition:filter .2s; user-select:none; min-width:260px;
    }
    .period-btn:hover { filter:brightness(1.12); }

    .period-btn-icon {
        width:32px; height:32px; border-radius:8px;
        background:rgba(255,255,255,.18);
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0; color:#fff; font-size:14px;
    }
    .period-btn-text  { flex:1; text-align:left; }
    .period-btn-label { font-size:10px; color:rgba(255,255,255,.6); margin-bottom:1px; }
    .period-btn-value { font-size:13px; font-weight:700; color:#fff; line-height:1.3; }
    .period-chevron   { color:rgba(255,255,255,.7); font-size:11px; transition:transform .2s; flex-shrink:0; }
    .period-selector-wrap.open .period-chevron { transform:rotate(180deg); }

    .period-dd {
        display:none; position:absolute; top:calc(100% + 8px); right:0;
        min-width:290px; background:var(--card,#fff);
        border:1px solid var(--border,#e2e8f0); border-radius:12px;
        box-shadow:0 10px 36px rgba(0,0,0,.18); z-index:999;
        padding:8px; flex-direction:column; gap:2px;
        max-height:320px; overflow-y:auto;
    }
    .period-selector-wrap.open .period-dd { display:flex; }

    .pd-section-label {
        font-size:10px; font-weight:700; text-transform:uppercase;
        letter-spacing:.9px; color:var(--muted,#888); padding:6px 10px 4px;
    }
    .pd-opt {
        display:flex; align-items:center; justify-content:space-between;
        padding:9px 12px; border-radius:8px; font-size:13px; font-weight:600;
        color:var(--text,#1a1a2e); cursor:pointer; transition:background .15s; gap:8px;
    }
    .pd-opt:hover { background:rgba(0,0,0,.04); }
    .pd-opt.selected { background:rgba(66,153,225,.1); color:#3182ce; }
    .pd-opt.selected .pd-check { display:block; }
    .pd-check { display:none; font-size:11px; color:#3182ce; flex-shrink:0; }
    .pd-opt-status {
        font-size:10px; font-weight:700; padding:2px 7px;
        border-radius:20px; flex-shrink:0;
    }
    .pd-opt-status.active    { background:rgba(72,187,120,.15); color:#38a169; }
    .pd-opt-status.completed { background:rgba(160,174,192,.15); color:#718096; }
    .pd-loading,.pd-empty { padding:20px; text-align:center; font-size:12px; color:var(--muted,#888); }
    .pd-divider { border:none; border-top:1px solid var(--border,#e2e8f0); margin:4px 0; }

    /* ── SEARCH AUTOCOMPLETE ── */
    .search-wrap { position:relative; flex:1; max-width:480px; }
    .search-wrap input {
        width:100%; padding:9px 12px 9px 36px;
        border:1px solid #dee2e6; border-radius:8px;
        font-size:13px; font-family:inherit; outline:none;
        transition:border-color .2s;
    }
    .search-wrap input:focus { border-color:#2d6a4f; }

    .autocomplete-list {
        display:none; position:absolute; top:calc(100% + 4px); left:0; right:0;
        background:#fff; border:1px solid #dee2e6; border-radius:10px;
        box-shadow:0 8px 24px rgba(0,0,0,.13); z-index:900;
        max-height:320px; overflow-y:auto;
    }
    .autocomplete-list.open { display:block; }

    .ac-item {
        display:flex; align-items:center; gap:12px;
        padding:10px 14px; cursor:pointer; transition:background .12s;
        border-bottom:1px solid #f0f0f0;
    }
    .ac-item:last-child { border-bottom:none; }
    .ac-item:hover { background:#f0fdf4; }
    .ac-item.already { opacity:.55; cursor:not-allowed; }

    .ac-code {
        font-size:11px; font-weight:700; background:#e8f5e9; color:#2d6a4f;
        padding:3px 8px; border-radius:6px; white-space:nowrap; flex-shrink:0;
    }
    .ac-info { flex:1; min-width:0; }
    .ac-subj { font-size:13px; font-weight:600; color:#1a1a2e; }
    .ac-desc { font-size:11px; color:#888; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ac-inst { font-size:11px; color:#aaa; white-space:nowrap; flex-shrink:0; }
    .ac-added-badge {
        font-size:10px; font-weight:700; color:#38a169;
        background:rgba(72,187,120,.15); padding:2px 8px; border-radius:20px; flex-shrink:0;
    }
    .ac-empty { padding:20px; text-align:center; font-size:12px; color:#aaa; }

    /* ── SELECTED LIST ── */
    #selected-list { display:flex; flex-direction:column; gap:0; }

    .sel-row {
        display:flex; align-items:center; gap:12px;
        padding:11px 16px; border-bottom:1px solid var(--border,#e2e8f0);
        animation:slideIn .18s ease;
    }
    .sel-row:last-child { border-bottom:none; }
    @@keyframes slideIn { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:none; } }
    .sel-code {
        font-size:11px; font-weight:700;
        background:#e8f5e9; color:#2d6a4f;
        padding:3px 8px; border-radius:6px; white-space:nowrap; flex-shrink:0;
    }
    .sel-subj { font-size:13px; font-weight:600; color:#1a1a2e; flex:1; min-width:0; }
    .sel-desc { font-size:12px; color:#666; flex:2; min-width:0; }
    .sel-inst { font-size:12px; color:#aaa; flex-shrink:0; }
    .sel-remove {
        background:none; border:none; cursor:pointer;
        color:#ccc; font-size:17px; padding:0 2px;
        transition:color .15s; flex-shrink:0;
    }
    .sel-remove:hover { color:#dc3545; }

    .empty-state {
        display:flex; flex-direction:column; align-items:center;
        padding:48px 24px; gap:12px; text-align:center;
    }
    .empty-icon {
        width:72px; height:72px; border-radius:50%;
        background:#f0fdf4; border:2px solid #bbf7d0;
        display:flex; align-items:center; justify-content:center;
        font-size:28px; color:#16a34a;
    }
</style>

<!-- STEP 1: SEARCH & SELECT -->
<div id="step-select" style="display:@(showConfirm ? "none" : "block")">

    <!-- HEADER -->
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <h5 class="fw-bold mb-0" style="color:#1a1a2e;font-size:15px;"></h5>

        <!-- PERIOD SELECTOR -->
        <div class="period-selector-wrap" id="period-wrap">
            <button class="period-btn" id="period-btn" onclick="togglePeriodDd(event)" type="button">
                <div class="period-btn-icon"><i class="fas fa-calendar-alt"></i></div>
                <div class="period-btn-text">
                    <div class="period-btn-label">Academic Period</div>
                    <div class="period-btn-value" id="period-btn-value">
                        @(Model?.ActivePeriod ?? "Loading...")
                    </div>
                </div>
                <i class="fas fa-chevron-down period-chevron"></i>
            </button>

            <div class="period-dd" id="period-dd">
                <div class="pd-loading" id="pd-loading">
                    <i class="fas fa-spinner fa-spin me-2"></i>Loading periods...
                </div>
            </div>
        </div>
    </div>

    <!-- SEARCH CARD -->
    <div class="page-card">
        <div class="page-card-hd dark">
            <i class="fas fa-search me-2"></i>Search &amp; Add Subjects
        </div>

        <div style="padding:14px 16px;border-bottom:1px solid var(--border);
                    display:flex;align-items:center;gap:10px;">
            <div class="search-wrap">
                <i class="fas fa-search"
                   style="position:absolute;left:12px;top:50%;
                          transform:translateY(-50%);color:#aaa;font-size:13px;"></i>
                <input type="text"
                       id="subject-search"
                       placeholder="Type to search by MIS code, subject, description or instructor…"
                       autocomplete="off"
                       oninput="onSearchInput(this.value)" />
                <div class="autocomplete-list" id="autocomplete-list"></div>
            </div>
            <span id="sel-count-badge"
                  style="font-size:12px;color:#2d6a4f;font-weight:700;
                         white-space:nowrap;display:none;">
                <i class="fas fa-check-circle me-1"></i>
                <span id="sel-count-num">0</span> selected
            </span>
        </div>

        <!-- SELECTED SUBJECTS LIST -->
        <div id="selected-area">
            <div class="empty-state" id="empty-state">
                <div class="empty-icon"><i class="fas fa-book-open"></i></div>
                <div style="font-size:15px;font-weight:700;color:#1a1a2e;">No subjects added yet</div>
                <div style="font-size:13px;color:#888;line-height:1.7;max-width:340px;">
                    Use the search box above to find your enrolled subjects,
                    then click a result to add it to your list.
                </div>
            </div>

            <div id="selected-list"></div>
        </div>

        <div style="padding:14px 20px;border-top:1px solid var(--border);text-align:right;">
            <button class="btn-green" onclick="showConfirmStep()">
                <i class="fas fa-arrow-right me-2"></i>Proceed to Confirm
            </button>
        </div>
    </div>
</div>

<!-- STEP 2: CONFIRM -->
<div id="step-confirm" style="display:@(showConfirm ? "block" : "none")">
    <div class="page-card">
        <div style="padding:18px 20px;text-align:center;font-size:14px;
                    font-weight:500;color:#333;border-bottom:1px solid var(--border);">
            <i class="fas fa-question-circle me-2" style="color:#1a4731;"></i>
            Are you sure these are all the subjects you're enrolled in this semester?
        </div>

        <div class="page-card-hd" style="font-size:14px;">Selected Subjects</div>

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>MIS CODE</th>
                        <th>SUBJECT CODE</th>
                        <th>DESCRIPTION</th>
                        <th>INSTRUCTOR</th>
                        <th style="width:60px;">ACTION</th>
                    </tr>
                </thead>
                <tbody id="confirm-body"></tbody>
            </table>
            <div id="confirm-empty"
                 style="display:none;padding:20px;text-align:center;
                        font-size:13px;color:#888;">
                No subjects selected. Please go back and select at least one.
            </div>
        </div>

        <div style="padding:16px 20px;background:#f8f9fa;
                    display:flex;gap:12px;justify-content:space-between;align-items:center;">
            <button class="btn-dark" onclick="backToSelect()">
                <i class="fas fa-arrow-left me-2"></i>BACK
            </button>
            <form asp-action="ConfirmSubjects" asp-controller="Student"
                  method="post" id="confirm-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="selectedSubjects" id="selected-hidden" />
                <input type="hidden" name="periodId" value="@Model.ActivePeriodId" />
                <button type="submit" id="submit-btn"
                        class="btn-green" onclick="return prepareSubmit()">
                    <i class="fas fa-check me-2"></i>YES, Confirm
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ══════════════════════════════════════════════════════════
   DATA — built from Razor model
══════════════════════════════════════════════════════════ */
const ALL_SUBJECTS = [
@if (Model?.AvailableSubjects != null)
{
    foreach (var s in Model.AvailableSubjects)
    {
        <text>
    {
        mis:      @Html.Raw(Json.Serialize(s.MisCode)),
        subj:     @Html.Raw(Json.Serialize(s.SubjectCode)),
        desc:     @Html.Raw(Json.Serialize(s.Description)),
        inst:     @Html.Raw(Json.Serialize(s.InstructorName)),
        enrolled: @Html.Raw(s.AlreadyEnrolled ? "true" : "false"),
        status:   @Html.Raw(Json.Serialize(s.EnrolledStatus))
    },
        </text>
    }
}
];

/* ══════════════════════════════════════════════════════════
   STATE
══════════════════════════════════════════════════════════ */
// mis codes already enrolled (pre-existing, not newly picked)
const ALREADY_ENROLLED = new Set(
    ALL_SUBJECTS.filter(s => s.enrolled).map(s => s.mis)
);

// newly selected by the user in this session
const selected = new Map(); // mis => subject object

/* ══════════════════════════════════════════════════════════
   SEARCH / AUTOCOMPLETE
══════════════════════════════════════════════════════════ */
function onSearchInput(val) {
    const q = val.trim().toLowerCase();
    const list = document.getElementById('autocomplete-list');

    if (!q) { list.classList.remove('open'); list.innerHTML = ''; return; }

    const matches = ALL_SUBJECTS.filter(s =>
        s.mis.toLowerCase().includes(q)  ||
        s.subj.toLowerCase().includes(q) ||
        s.desc.toLowerCase().includes(q) ||
        s.inst.toLowerCase().includes(q)
    ).slice(0, 12);

    if (!matches.length) {
        list.innerHTML = '<div class="ac-empty"><i class="fas fa-search me-1"></i>No subjects found.</div>';
        list.classList.add('open');
        return;
    }

    list.innerHTML = matches.map(s => {
        const isEnrolled = ALREADY_ENROLLED.has(s.mis);
        const isSelected = selected.has(s.mis);
        const cls = isEnrolled ? 'ac-item already' : 'ac-item';

        const rightBadge = isEnrolled
            ? `<span class="ac-added-badge" style="background:rgba(246,173,85,.15);color:#f6ad55;">${esc(s.status || 'Enrolled')}</span>`
            : isSelected
                ? `<span class="ac-added-badge">&#10003; Added</span>`
                : `<span style="font-size:11px;color:#bbb;">click to add</span>`;

        return `<div class="${cls}" onclick="addSubject('${esc(s.mis)}')">
            <span class="ac-code">${esc(s.mis)}</span>
            <div class="ac-info">
                <div class="ac-subj">${esc(s.subj)}</div>
                <div class="ac-desc">${esc(s.desc)}</div>
            </div>
            <span class="ac-inst">${esc(s.inst)}</span>
            ${rightBadge}
        </div>`;
    }).join('');

    list.classList.add('open');
}

/* Close autocomplete on outside click */
document.addEventListener('click', e => {
    const wrap = document.querySelector('.search-wrap');
    if (!wrap?.contains(e.target)) {
        document.getElementById('autocomplete-list').classList.remove('open');
    }
});

/* ══════════════════════════════════════════════════════════
   ADD / REMOVE
══════════════════════════════════════════════════════════ */
function addSubject(mis) {
    if (ALREADY_ENROLLED.has(mis)) return; // already enrolled — ignore
    if (selected.has(mis)) return;         // already picked

    const s = ALL_SUBJECTS.find(x => x.mis === mis);
    if (!s) return;

    selected.set(mis, s);
    renderSelectedList();
    updateCountBadge();

    // refresh autocomplete to show "Added" badge
    onSearchInput(document.getElementById('subject-search').value);
}

function removeSubject(mis) {
    selected.delete(mis);
    renderSelectedList();
    updateCountBadge();
    onSearchInput(document.getElementById('subject-search').value);
}

function renderSelectedList() {
    const list  = document.getElementById('selected-list');
    const empty = document.getElementById('empty-state');

    if (selected.size === 0) {
        list.innerHTML  = '';
        empty.style.display = 'flex';
        return;
    }

    empty.style.display = 'none';
    list.innerHTML = [...selected.values()].map(s => `
        <div class="sel-row" id="sel-${esc(s.mis)}">
            <span class="sel-code">${esc(s.mis)}</span>
            <span class="sel-subj">${esc(s.subj)}</span>
            <span class="sel-desc">${esc(s.desc)}</span>
            <span class="sel-inst">${esc(s.inst)}</span>
            <button class="sel-remove" onclick="removeSubject('${esc(s.mis)}')" title="Remove">
                <i class="fas fa-times-circle"></i>
            </button>
        </div>
    `).join('');
}

function updateCountBadge() {
    const badge = document.getElementById('sel-count-badge');
    const num   = document.getElementById('sel-count-num');
    num.textContent  = selected.size;
    badge.style.display = selected.size > 0 ? 'inline-flex' : 'none';
}

/* ══════════════════════════════════════════════════════════
   CONFIRM STEP
══════════════════════════════════════════════════════════ */
function showConfirmStep() {
    if (selected.size === 0) {
        alert('Please search and add at least one subject.');
        return;
    }

    const tbody = document.getElementById('confirm-body');
    tbody.innerHTML = [...selected.values()].map(s => `
        <tr id="confirm-row-${esc(s.mis)}">
            <td><span class="code-badge">${esc(s.mis)}</span></td>
            <td style="font-weight:600;">${esc(s.subj)}</td>
            <td>${esc(s.desc)}</td>
            <td>${esc(s.inst)}</td>
            <td style="text-align:center;">
                <button type="button" onclick="removeConfirmRow('${esc(s.mis)}')"
                        style="background:none;border:none;cursor:pointer;
                               color:#dc3545;font-size:18px;" title="Remove">
                    <i class="fas fa-times-circle"></i>
                </button>
            </td>
        </tr>
    `).join('');

    document.getElementById('step-select').style.display  = 'none';
    document.getElementById('step-confirm').style.display = 'block';
    checkConfirmEmpty();
}

function removeConfirmRow(mis) {
    document.getElementById('confirm-row-' + mis)?.remove();
    selected.delete(mis);
    checkConfirmEmpty();
    renderSelectedList();
    updateCountBadge();
}

function checkConfirmEmpty() {
    const rows  = document.querySelectorAll('#confirm-body tr');
    const empty = document.getElementById('confirm-empty');
    const btn   = document.getElementById('submit-btn');
    empty.style.display = rows.length === 0 ? 'block' : 'none';
    btn.disabled        = rows.length === 0;
}

function backToSelect() {
    document.getElementById('step-select').style.display  = 'block';
    document.getElementById('step-confirm').style.display = 'none';
}

function prepareSubmit() {
    const misCodes = [...selected.keys()];
    if (misCodes.length === 0) {
        alert('You have removed all subjects. Please go back and add at least one.');
        return false;
    }
    document.getElementById('selected-hidden').value = misCodes.join(',');
    return true;
}

/* ══════════════════════════════════════════════════════════
   PERIOD DROPDOWN
══════════════════════════════════════════════════════════ */
// The server already loaded subjects for this periodId
const _serverPeriodId = @Model.ActivePeriodId;
let allPeriods = [], selectedPeriodId = _serverPeriodId;

async function loadPeriods() {
    const dd = document.getElementById('period-dd');
    try {
        const res = await fetch('/api/student/periods');
        allPeriods = await res.json();
    } catch { allPeriods = []; }

    dd.innerHTML = '';
    if (!allPeriods.length) {
        dd.innerHTML = '<div class="pd-empty"><i class="fas fa-calendar-times me-2"></i>No academic periods found.</div>';
        return;
    }

    // Pre-select: use the period the server rendered, or fall back to Active
    const preselected = allPeriods.find(p => p.id === _serverPeriodId)
                     ?? allPeriods.find(p => p.status === 'Active')
                     ?? allPeriods[0];
    selectedPeriodId = preselected.id;
    updatePeriodDisplay(preselected);

    allPeriods.forEach(p => {
        const opt = document.createElement('div');
        opt.className  = 'pd-opt' + (p.id === selectedPeriodId ? ' selected' : '');
        opt.dataset.id = p.id;
        opt.innerHTML  = `
            <span style="flex:1;">A.Y. ${esc(p.ay)}, ${esc(p.sem)}</span>
            <span class="pd-opt-status ${p.status === 'Active' ? 'active' : 'completed'}">${esc(p.status)}</span>
            <i class="fas fa-check pd-check"></i>`;
        opt.onclick = e => { e.stopPropagation(); selectPeriod(p); };
        dd.appendChild(opt);
    });
}

function selectPeriod(p) {
    // Reload the page for the chosen period so subjects come from the DB
    window.location.href = '/Student/SubjectsOffered?periodId=' + p.id;
}

function updatePeriodDisplay(p) {
    document.getElementById('period-btn-value').textContent = `A.Y. ${p.ay}, ${p.sem}`;
}

function togglePeriodDd(e) { e.stopPropagation(); document.getElementById('period-wrap').classList.toggle('open'); }
function closePeriodDd() { document.getElementById('period-wrap').classList.remove('open'); }

document.addEventListener('click', e => {
    const wrap = document.getElementById('period-wrap');
    if (wrap && !wrap.contains(e.target)) closePeriodDd();
});

/* ══════════════════════════════════════════════════════════
   UTIL
══════════════════════════════════════════════════════════ */
function esc(str) {
    return String(str ?? '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// Init
loadPeriods();
</script>
}
