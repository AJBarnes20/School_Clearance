    .pd-opt-status.completed { background:rgba(160,174,192,0.15);color:#718096; }
    .pd-loading,.pd-empty    { padding:20px;text-align:center;font-size:12px;color:var(--muted,#888); }
    .pd-divider { border:none;border-top:1px solid var(--border,#e2e8f0);margin:4px 0; }

    /* ── Empty state ── */
    .empty-state {
        display:flex;flex-direction:column;align-items:center;
        justify-content:center;padding:52px 24px;text-align:center;gap:12px;
    }
    .empty-icon {
        width:72px;height:72px;border-radius:50%;
