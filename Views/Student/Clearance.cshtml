    .chat-bubble.theirs { background:white;color:#1a1a2e;border:1px solid #e2e8f0;border-bottom-left-radius:4px; }
    .chat-time {
        font-size:10px;color:#aaa;margin-top:3px;padding:0 4px;
    }
    .chat-sender-name {
        font-size:10px;font-weight:700;color:#1a4731;margin-bottom:3px;padding:0 4px;
    }

    /* ── Chat date divider ── */
    .chat-date-divider {
        text-align:center;font-size:10px;color:#aaa;
        margin:6px 0;position:relative;
    }
    .chat-date-divider::before,.chat-date-divider::after {
        content:'';position:absolute;top:50%;
        width:30%;height:1px;background:#e2e8f0;
    }
    .chat-date-divider::before { left:0; }
    .chat-date-divider::after  { right:0; }
</style>
}

@section Scripts {
<script>
    const _csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    /* ══════════════════════════════════════════
       PERIOD DROPDOWN
    ══════════════════════════════════════════ */
    const _serverPeriodId = @(ViewData["ActivePeriodId"] is int svPid ? svPid : 0);
    let allPeriods = [], selectedPeriodId = _serverPeriodId;

    async function loadPeriods() {
        const dd = document.getElementById('period-dd');
        try {
            const res  = await fetch('/api/student/periods');
            allPeriods = await res.json();
        } catch { allPeriods = []; }

        dd.innerHTML = '';
        if (!allPeriods.length) {
            dd.innerHTML = '<div class="pd-empty"><i class="fas fa-calendar-times me-2"></i>No academic periods found.</div>';
            return;
        }

        const preselected = allPeriods.find(p => p.id === _serverPeriodId)
                         ?? allPeriods.find(p => p.status === 'Active')
                         ?? allPeriods[0];
        selectedPeriodId = preselected.id;
        updatePeriodDisplay(preselected);

        allPeriods.forEach(p => {
            const opt     = document.createElement('div');
            opt.className = 'pd-opt' + (p.id === selectedPeriodId ? ' selected' : '');
            opt.dataset.id = p.id;
            opt.innerHTML = `
                <span style="flex:1;">A.Y. ${escHtml(p.ay)}, ${escHtml(p.sem)}</span>
                <span class="pd-opt-status ${p.status === 'Active' ? 'active' : 'completed'}">${escHtml(p.status)}</span>
                <i class="fas fa-check pd-check"></i>`;
            opt.onclick = (e) => { e.stopPropagation(); selectPeriod(p); };
            dd.appendChild(opt);
        });
    }

    function selectPeriod(p) {
        // Reload page for the selected period so clearance data comes from DB
        window.location.href = '/Student/Clearance?periodId=' + p.id;
    }

    function updatePeriodDisplay(p) {
        document.getElementById('period-btn-value').textContent = `A.Y. ${p.ay}, ${p.sem}`;
    }

    function togglePeriodDd(e) { e.stopPropagation(); document.getElementById('period-wrap').classList.toggle('open'); }
    function closePeriodDd()    { document.getElementById('period-wrap').classList.remove('open'); }

    document.addEventListener('click', function(e) {
        const wrap = document.getElementById('period-wrap');
        if (wrap && !wrap.contains(e.target)) closePeriodDd();
    });

    /* ══════════════════════════════════════════
       REQUEST ORG CLEARANCE
    ══════════════════════════════════════════ */
    function requestOrg(position) {
        fetch('/Student/RequestOrgSignature', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
            body:    JSON.stringify({ orgName: position, periodId: _serverPeriodId })
        })
        .then(r => r.json())
        .then(d => { if (d.success) location.reload(); else alert(d.error ?? 'Request failed'); })
        .catch(err => console.warn('Request error:', err));
    }

    /* ══════════════════════════════════════════
       DELETE CLEARANCE
    ══════════════════════════════════════════ */
    function deleteClearance(type, key) {
        if (!confirm('Remove this pending clearance request?')) return;
        fetch('/Student/DeleteClearanceRequest', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
            body:    JSON.stringify({ type, key, periodId: _serverPeriodId })
        })
        .then(r => r.json())
        .then(d => { if (d.success) location.reload(); else alert(d.error ?? 'Delete failed'); })
        .catch(err => console.warn('Delete error:', err));
    }

    /* ══════════════════════════════════════════
       CHAT  — backed by clearance_messages table
    ══════════════════════════════════════════ */
    let currentChatKey  = null;
    let currentChatType = null;
    let currentChatName = null;

    function getInitials(name) {
        return (name ?? '').split(' ').filter(Boolean).map(w => w[0]).join('').slice(0, 2).toUpperCase();
    }

    function fmtTime(d) {
        return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    }

    function openChat(key, personName, type, role) {
        currentChatKey  = key;
        currentChatType = type;
        currentChatName = personName;

        document.getElementById('chat-name').textContent    = personName;
        document.getElementById('chat-role').textContent    = role;
        document.getElementById('chat-avatar').textContent  = getInitials(personName);

        const modal   = document.getElementById('chat-modal');
        const overlay = document.getElementById('chat-overlay');
        modal.style.display   = 'flex';
        overlay.style.display = 'block';

        // Show loading state then fetch from server
        document.getElementById('chat-messages').innerHTML =
            '<div style="text-align:center;margin:auto;font-size:12px;color:#aaa;">' +
            '<i class="fas fa-spinner fa-spin me-1"></i>Loading messages...</div>';

        fetchMessages();
        setTimeout(() => document.getElementById('chat-input').focus(), 80);
    }

    function closeChat() {
        document.getElementById('chat-modal').style.display   = 'none';
        document.getElementById('chat-overlay').style.display = 'none';
        currentChatKey  = null;
        currentChatType = null;
    }

    async function fetchMessages() {
        if (!currentChatKey) return;
        try {
            const res  = await fetch(
                `/Student/GetClearanceMessages?key=${encodeURIComponent(currentChatKey)}&type=${encodeURIComponent(currentChatType)}`
            );
            const data = await res.json();
            if (data.success) renderMessages(data.messages ?? []);
        } catch (err) {
            console.warn('Failed to load messages:', err);
        }
    }

    function renderMessages(msgs) {
        const box = document.getElementById('chat-messages');
        box.innerHTML = '';

        if (!msgs.length) {
            box.innerHTML = `
                <div style="text-align:center;margin:auto;">
                    <div style="font-size:32px;margin-bottom:10px;">💬</div>
                    <div style="font-size:13px;font-weight:700;color:#1a1a2e;margin-bottom:4px;">
                        Start the conversation
                    </div>
                    <div style="font-size:12px;color:#aaa;max-width:220px;margin:0 auto;line-height:1.6;">
                        Send a message to <strong>${escHtml(currentChatName)}</strong> about your clearance.
                    </div>
                </div>`;
            return;
        }

        let lastDate = null;
        msgs.forEach(m => {
            const d       = new Date(m.time);
            const dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

            if (dateStr !== lastDate) {
                const div       = document.createElement('div');
                div.className   = 'chat-date-divider';
                div.textContent = dateStr;
                box.appendChild(div);
                lastDate = dateStr;
            }

            const wrap     = document.createElement('div');
            wrap.className = 'chat-bubble-wrap ' + (m.mine ? 'mine' : 'theirs');

            if (!m.mine) {
                const sn       = document.createElement('div');
                sn.className   = 'chat-sender-name';
                sn.textContent = currentChatName;
                wrap.appendChild(sn);
            }

            const bubble       = document.createElement('div');
            bubble.className   = 'chat-bubble ' + (m.mine ? 'mine' : 'theirs');
            bubble.textContent = m.text;
            wrap.appendChild(bubble);

            const time       = document.createElement('div');
            time.className   = 'chat-time';
            time.textContent = fmtTime(d);
            wrap.appendChild(time);

            box.appendChild(wrap);
        });

        box.scrollTop = box.scrollHeight;
    }

    async function sendChatMessage() {
        const input = document.getElementById('chat-input');
        const text  = input.value.trim();
        if (!text || !currentChatKey) return;

        // Optimistically append the message in the UI
        const tempMsg = { mine: true, text, time: new Date().toISOString() };
        const existingMsgs = Array.from(document.querySelectorAll('#chat-messages .chat-bubble-wrap'))
            .length > 0;

        input.value = '';
        if (!existingMsgs) {
            // Was showing empty state; re-render with just this message
            renderMessages([tempMsg]);
        } else {
            // Append bubble directly
            appendBubble(tempMsg);
            document.getElementById('chat-messages').scrollTop = 999999;
        }

        try {
            const res  = await fetch('/Student/SendClearanceMessage', {
                method:  'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': _csrf
                },
                body: JSON.stringify({
                    clearanceType: currentChatType,
                    clearanceKey:  currentChatKey,
                    message:       text
                })
            });
            const data = await res.json();
            if (!data.success) console.warn('Message send failed:', data.error);
        } catch (err) {
            console.warn('Chat error:', err);
        }
    }

    function appendBubble(m) {
        const box  = document.getElementById('chat-messages');
        const wrap = document.createElement('div');
        wrap.className = 'chat-bubble-wrap ' + (m.mine ? 'mine' : 'theirs');

        const bubble       = document.createElement('div');
        bubble.className   = 'chat-bubble ' + (m.mine ? 'mine' : 'theirs');
        bubble.textContent = m.text;
        wrap.appendChild(bubble);

        const time       = document.createElement('div');
        time.className   = 'chat-time';
        time.textContent = fmtTime(new Date(m.time));
        wrap.appendChild(time);

        box.appendChild(wrap);
    }

    function escHtml(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeChat(); });

    loadPeriods();
</script>
}