@* ═══════════════════════════════════════════════════════════════════════════
   Views/Student/Clearance.cshtml  — Unified Subject + Organization Clearance
   ═══════════════════════════════════════════════════════════════════════════ *@
@model OnlineClearanceSystem.Models.StudentClearanceViewModel
@{
    ViewData["Title"]      = "Clearance";
    ViewData["ActivePage"] = "Clearance";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";

    bool hasSubjects = Model?.SubjectItems != null && Model.SubjectItems.Any();
    var  adviser     = Model?.ClassAdviser;
}

@Html.AntiForgeryToken()

@* ── Alerts ── *@
@if (TempData["OrgSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["OrgSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["OrgError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["OrgError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- HEADER ROW -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;font-size:15px;"></h5>

    <!-- PERIOD SELECTOR DROPDOWN -->
    <div class="period-selector-wrap" id="period-wrap">
        <button class="period-btn" id="period-btn" onclick="togglePeriodDd(event)" type="button">
            <div class="period-btn-icon"><i class="fas fa-calendar-alt"></i></div>
            <div class="period-btn-text">
                <div class="period-btn-label">Academic Period</div>
                <div class="period-btn-value" id="period-btn-value">
                    @(ViewData["ActivePeriod"]?.ToString() ?? "Loading...")
                </div>
            </div>
            <i class="fas fa-chevron-down period-chevron"></i>
        </button>

        <div class="period-dd" id="period-dd">
            <div class="pd-loading" id="pd-loading">
                <i class="fas fa-spinner fa-spin me-2"></i>Loading periods...
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════════
   SECTION 1 — SUBJECT CLEARANCE
   ══════════════════════════════════════════════════════════════════════════ *@

<div class="page-card mb-4">
    <div class="page-card-hd dark">
        <i class="fas fa-clipboard-list me-2"></i>Subjects Clearance
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Subject</th>
                    <th>Description</th>
                    <th>Instructor</th>
                    <th style="text-align:center;">Status</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (hasSubjects)
                {
                    foreach (var item in Model!.SubjectItems!)
                    {
                        <tr>
                            <td><span class="code-badge">@item.MisCode</span></td>
                            <td style="font-weight:600;">@item.SubjectCode</td>
                            <td>@item.Description</td>
                            <td>@item.InstructorName</td>
                            <td style="text-align:center;">
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Pending")
                                {
                                    <span class="status-pending">Pending</span>
                                }
                                else
                                {
                                    <span class="status-none">—</span>
                                }
                            </td>
                            <td style="text-align:center;">
                                <button class="chat-icon-btn"
                                        onclick="openChat('@item.MisCode', '@Html.Raw(item.InstructorName)', 'subject', '@item.SubjectCode')"
                                        title="Message @item.InstructorName">
                                    <i class="fas fa-comment-dots"></i>
                                </button>
                                @if (item.Status == "Pending")
                                {
                                    <button class="delete-icon-btn"
                                            onclick="deleteClearance('subject', '@item.MisCode')"
                                            title="Delete clearance request">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <div class="empty-icon">
                                    <i class="fas fa-clipboard-list"></i>
                                </div>
                                <div class="empty-title">No selected subjects yet</div>
                                <div class="empty-desc">
                                    You haven't confirmed your subjects yet.<br />
                                    Go to <strong>Subjects Offered</strong> to select
                                    and confirm your enrolled subjects first.
                                </div>
                                <a href="/Student/SubjectsOffered" class="btn-green"
                                   style="display:inline-flex;align-items:center;
                                          gap:8px;padding:10px 28px;
                                          text-decoration:none;margin-top:4px;">
                                    <i class="fas fa-book-open"></i>
                                    Go to Subjects Offered
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════════
   SECTION 2 — CLASS ADVISER
   ══════════════════════════════════════════════════════════════════════════ *@

@if (adviser != null)
{
    <div class="page-card mb-3">
        <div class="page-card-hd dark">
            <i class="fas fa-chalkboard-teacher me-2"></i>Class Adviser
        </div>
        <div class="adviser-card-body">

            <div class="adviser-meta-col">
                <div class="adviser-label">Advisory</div>
                <div class="adviser-value">@adviser.OrgRole</div>
            </div>

            <div class="adviser-divider"></div>

            <div class="adviser-meta-col">
                <div class="adviser-label">Adviser</div>
                <div class="adviser-value">@adviser.PersonName</div>
            </div>

            <div class="adviser-actions">
                @switch (adviser.Status)
                {
                    case "Cleared":
                        <span class="status-approved">Cleared</span>
                        break;
                    case "Declined":
                        <span class="status-declined">Declined</span>
                        break;
                    case "Pending":
                        <span class="status-pending">Pending</span>
                        break;
                    default:
                        <button class="request-btn"
                                onclick="requestOrg('@Html.Raw(adviser.OrgName)')">
                            <i class="fas fa-paper-plane"></i> Request
                        </button>
                        break;
                }

                <button class="chat-icon-btn"
                        onclick="openChat('@adviser.OrgName', '@Html.Raw(adviser.PersonName)', 'org', '@adviser.OrgRole')"
                        title="Message @adviser.PersonName">
                    <i class="fas fa-comment-dots"></i>
                </button>

                @if (adviser.Status == "Pending")
                {
                    <button class="delete-icon-btn"
                            onclick="deleteClearance('org', '@adviser.OrgName')"
                            title="Delete adviser clearance request">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                }
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════════════
   SECTION 3 — ORGANIZATION CLEARANCE
   ══════════════════════════════════════════════════════════════════════════ *@

<div class="page-card mb-4">
    <div class="page-card-hd dark">
        <i class="fas fa-sitemap me-2"></i>Organization Clearance
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:60px;text-align:center;">No.</th>
                    <th>Position</th>
                    <th>Signatory</th>
                    <th style="text-align:center;">Status</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.OrgItems != null && Model.OrgItems.Any())
                {
                    int i = 1;
                    foreach (var item in Model.OrgItems)
                    {
                        <tr>
                            <td style="text-align:center;">
                                <span class="code-badge">@i.ToString("D2")</span>
                            </td>
                            <td style="font-weight:600;">@item.OrgRole</td>
                            <td>@item.PersonName</td>
                            <td style="text-align:center;">
                                @switch (item.Status)
                                {
                                    case "Cleared":
                                        <span class="status-approved">Cleared</span>
                                        break;
                                    case "Declined":
                                        <span class="status-declined">Declined</span>
                                        break;
                                    case "Pending":
                                        <span class="status-pending">Pending</span>
                                        break;
                                    default:
                                        <span style="color:#aaa;font-size:12px;">—</span>
                                        break;
                                }
                            </td>
                            <td style="text-align:center;">
                                @if (string.IsNullOrEmpty(item.Status))
                                {
                                    <button class="request-btn"
                                            onclick="requestOrg('@Html.Raw(item.OrgName)')">
                                        <i class="fas fa-paper-plane"></i> Request
                                    </button>
                                }
                                <button class="chat-icon-btn"
                                        onclick="openChat('@item.OrgName', '@Html.Raw(item.PersonName)', 'org', '@item.OrgRole')"
                                        title="Message @item.PersonName">
                                    <i class="fas fa-comment-dots"></i>
                                </button>
                                @if (item.Status == "Pending")
                                {
                                    <button class="delete-icon-btn"
                                            onclick="deleteClearance('org', '@item.OrgName')"
                                            title="Delete clearance request">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="padding:40px;text-align:center;color:#888;">
                            <i class="fas fa-sitemap"
                               style="font-size:28px;color:#ddd;display:block;margin-bottom:10px;"></i>
                            No organization signatories assigned to your curriculum yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════════
   CHAT MODAL
   ══════════════════════════════════════════════════════════════════════════ *@

<div id="chat-overlay" onclick="closeChat()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1040;"></div>

<div id="chat-modal" style="display:none;position:fixed;bottom:0;right:24px;width:360px;
     height:520px;background:white;border-radius:16px 16px 0 0;
     box-shadow:0 -4px 40px rgba(0,0,0,0.18);z-index:1050;
     display:none;flex-direction:column;overflow:hidden;">

    <!-- MODAL HEADER -->
    <div id="chat-header" style="background:var(--green,#1a4731);padding:14px 16px;
         display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <div id="chat-avatar" style="width:38px;height:38px;border-radius:50%;
             background:rgba(255,255,255,0.2);display:flex;align-items:center;
             justify-content:center;font-size:15px;font-weight:700;color:white;flex-shrink:0;">
        </div>
        <div style="flex:1;min-width:0;">
            <div id="chat-name" style="font-size:13px;font-weight:700;color:white;
                 white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
            <div id="chat-role" style="font-size:11px;color:rgba(255,255,255,0.65);margin-top:1px;"></div>
        </div>
        <button onclick="closeChat()" style="background:none;border:none;color:rgba(255,255,255,0.7);
                font-size:16px;cursor:pointer;padding:4px;line-height:1;">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <!-- MESSAGES AREA -->
    <div id="chat-messages" style="flex:1;overflow-y:auto;padding:16px;
         display:flex;flex-direction:column;gap:10px;background:#f7f8fa;">
        <!-- messages injected here -->
    </div>

    <!-- INPUT AREA -->
    <div style="padding:12px 14px;border-top:1px solid #e2e8f0;background:white;
         display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <input id="chat-input" type="text" placeholder="Type a message…"
               style="flex:1;border:1px solid #d1d5db;border-radius:22px;
                      padding:9px 14px;font-size:13px;outline:none;font-family:inherit;
                      background:#f7f8fa;"
               onkeydown="if(event.key==='Enter')sendChatMessage()" />
        <button onclick="sendChatMessage()"
                style="width:38px;height:38px;border-radius:50%;border:none;
                       background:var(--green,#1a4731);color:white;font-size:14px;
                       cursor:pointer;display:flex;align-items:center;justify-content:center;
                       flex-shrink:0;">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

@section Styles {
<style>
    /* ── PERIOD SELECTOR ── */
    .period-selector-wrap { position:relative;display:inline-block; }
    .period-btn {
        display:flex;align-items:center;gap:10px;
        background:linear-gradient(135deg,#1a4731,#2d6a4f);
        border:none;border-radius:10px;padding:9px 16px;
        cursor:pointer;transition:filter 0.2s;user-select:none;min-width:260px;
    }
    .period-btn:hover { filter:brightness(1.12); }
    .period-btn-icon {
        width:32px;height:32px;border-radius:8px;
        background:rgba(255,255,255,0.18);
        display:flex;align-items:center;justify-content:center;
        flex-shrink:0;color:white;font-size:14px;
    }
    .period-btn-text  { flex:1;text-align:left; }
    .period-btn-label { font-size:10px;color:rgba(255,255,255,0.6);margin-bottom:1px; }
    .period-btn-value { font-size:13px;font-weight:700;color:#fff;line-height:1.3; }
    .period-chevron   { color:rgba(255,255,255,0.7);font-size:11px;transition:transform 0.2s;flex-shrink:0; }
    .period-selector-wrap.open .period-chevron { transform:rotate(180deg); }

    /* ── DROPDOWN ── */
    .period-dd {
        display:none;position:absolute;top:calc(100% + 8px);right:0;
        min-width:290px;background:var(--card,#fff);
        border:1px solid var(--border,#e2e8f0);border-radius:12px;
        box-shadow:0 10px 36px rgba(0,0,0,0.18);z-index:999;
        padding:8px;flex-direction:column;gap:2px;
        max-height:320px;overflow-y:auto;
    }
    .period-selector-wrap.open .period-dd { display:flex; }
    .pd-section-label {
        font-size:10px;font-weight:700;text-transform:uppercase;
        letter-spacing:0.9px;color:var(--muted,#888);padding:6px 10px 4px;
    }
    .pd-opt {
        display:flex;align-items:center;justify-content:space-between;
        padding:9px 12px;border-radius:8px;font-size:13px;font-weight:600;
        color:var(--text,#1a1a2e);cursor:pointer;transition:background 0.15s;gap:8px;
