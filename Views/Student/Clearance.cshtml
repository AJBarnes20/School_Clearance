    /* ── Status badges ── */
    .status-pending  { background:#fff8e1;color:#e6a817;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700; }
    .status-approved { background:#e8f5e9;color:#2e7d32;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700; }
    .status-declined { background:#fce4ec;color:#c62828;border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700; }
