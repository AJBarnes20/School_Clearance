@model OnlineClearanceSystem.Models.StudentClearancePdfViewModel
@{
    ViewData["Title"]      = "Download PDF";
    ViewData["ActivePage"] = "DownloadPdf";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<!-- TOOLBAR -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">

    <!-- PERIOD SELECTOR -->
    <div class="period-selector-wrap" id="period-wrap">
        <button class="period-btn" id="period-btn" onclick="togglePeriodDd(event)" type="button">
            <div class="period-btn-icon"><i class="fas fa-calendar-alt"></i></div>
            <div class="period-btn-text">
                <div class="period-btn-label">Academic Period</div>
                <div class="period-btn-value" id="period-btn-value">
                    @(string.IsNullOrEmpty(Model?.AySemester) ? "Loading..." : "A.Y. " + Model!.AySemester.Replace(" / ", ", "))
                </div>
            </div>
            <i class="fas fa-chevron-down period-chevron"></i>
        </button>
        <div class="period-dd" id="period-dd">
            <div style="padding:20px;text-align:center;font-size:12px;color:#888;">
                <i class="fas fa-spinner fa-spin me-2"></i>Loading periods...
            </div>
        </div>
    </div>

    <button class="btn-green" onclick="window.print()" style="padding:9px 22px;">
        <i class="fas fa-print me-2"></i>Print / Download
    </button>
</div>

<!-- DOCUMENT PREVIEW -->
<div style="background:white;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.1);
            overflow:hidden;" id="pdf-preview">
    <div id="clearance-doc"
         style="padding:32px 48px;max-width:740px;margin:0 auto;
                font-family:'Times New Roman',serif;">

        <!-- HEADER -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
            <div style="width:70px;height:70px;border-radius:50%;background:#7a1515;
                        display:flex;align-items:center;justify-content:center;
                        overflow:hidden;flex-shrink:0;">
                <img src="/images/Cebu_Technological_University_Logo.png" alt="CTU Seal"
                     style="width:100%;height:100%;object-fit:cover;">
            </div>
            <div style="text-align:center;flex:1;padding:0 16px;">
                <div style="font-size:11px;color:#333;">Republic of the Philippines</div>
                <div style="font-size:14px;font-weight:700;color:#111;">
                    CEBU TECHNOLOGICAL UNIVERSITY
                </div>
                <div style="font-size:12px;font-weight:600;">GINATILAN EXTENSION CAMPUS</div>
                <div style="font-size:10px;color:#555;">Ginatilan, Cebu</div>
            </div>
            <div style="width:70px;height:70px;flex-shrink:0;
                        display:flex;align-items:center;justify-content:center;">
                <img src="/images/Bagong_Pilipinas_logo.png" alt="Bagong Pilipinas"
                     style="width:60px;height:60px;object-fit:contain;">
            </div>
        </div>

        <hr style="border:2px solid #333;margin:10px 0 4px;" />
        <hr style="border:1px solid #333;margin:0 0 18px;" />

        <div style="text-align:center;margin-bottom:24px;">
            <h2 style="font-size:20px;font-weight:900;letter-spacing:1px;margin:0;">
                DEPARTMENTAL<br />CLEARANCE
            </h2>
        </div>

        <!-- STUDENT INFO -->
        <table style="width:100%;border-collapse:collapse;margin-bottom:18px;font-size:13px;">
            <tr>
                <td style="padding:3px 0;width:140px;color:#555;">Student Name:</td>
                <td style="padding:3px 8px;border-bottom:1px solid #333;font-weight:700;">
                    @(Model?.StudentName ?? "")
                </td>
                <td style="padding:3px 0 3px 24px;width:110px;color:#555;">Student ID:</td>
                <td style="padding:3px 8px;border-bottom:1px solid #333;font-weight:700;">
                    @(Model?.StudentId ?? "")
                </td>
            </tr>
            <tr>
                <td style="padding:6px 0;color:#555;">Course &amp; Year:</td>
                <td style="padding:6px 8px;border-bottom:1px solid #333;font-weight:700;">
                    @(Model?.CourseYear ?? "")
                </td>
                <td style="padding:6px 0 6px 24px;color:#555;">A.Y. / Sem:</td>
                <td style="padding:6px 8px;border-bottom:1px solid #333;font-weight:700;">
                    @(Model?.AySemester ?? "")
                </td>
            </tr>
        </table>

        <!-- SUBJECT CLEARANCES -->
        <div style="font-size:12px;font-weight:700;margin-bottom:6px;text-decoration:underline;">
            SUBJECT CLEARANCES
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:12px;margin-bottom:18px;">
            <thead>
                <tr style="background:#1a4731;color:white;">
                    <th style="padding:7px 10px;text-align:left;">Code</th>
                    <th style="padding:7px 10px;text-align:left;">Subject</th>
                    <th style="padding:7px 10px;text-align:left;">Description</th>
                    <th style="padding:7px 10px;text-align:left;">Instructor</th>
                    <th style="padding:7px 10px;text-align:center;">Signature</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Subjects != null && Model.Subjects.Any())
                {
                    foreach (var row in Model.Subjects)
                    {
                        <tr style="border-bottom:1px solid #dee2e6;">
                            <td style="padding:6px 10px;">@row.MisCode</td>
                            <td style="padding:6px 10px;">@row.SubjectCode</td>
                            <td style="padding:6px 10px;">@row.Description</td>
                            <td style="padding:6px 10px;">@row.InstructorName</td>
                            <td style="padding:6px 10px;text-align:center;border-bottom:1px solid #333;min-width:100px;">
                                @if (row.Status == "Cleared" && !string.IsNullOrEmpty(row.SignatureBase64))
                                {
                                    <img src="@row.SignatureBase64"
                                         style="max-height:40px;max-width:90px;object-fit:contain;filter:invert(1);" />
                                }
                                else if (row.Status == "Cleared")
                                {
                                    <span style="color:#28a745;font-weight:700;">✔</span>
                                }
                                else
                                {
                                    @:&nbsp;
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="padding:20px;text-align:center;color:#888;font-style:italic;">
                            No subjects enrolled for this period.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- ORGANIZATION CLEARANCES -->
        <div style="font-size:12px;font-weight:700;margin-bottom:6px;text-decoration:underline;">
            ORGANIZATION CLEARANCES
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:12px;margin-bottom:24px;">
            <thead>
                <tr style="background:#1a4731;color:white;">
                    <th style="padding:7px 10px;text-align:left;">#</th>
                    <th style="padding:7px 10px;text-align:left;">Organization / Position</th>
                    <th style="padding:7px 10px;text-align:left;">Signatory</th>
                    <th style="padding:7px 10px;text-align:center;">Status</th>
                    <th style="padding:7px 10px;text-align:center;">Signature</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Organizations != null && Model.Organizations.Any())
                {
                    int i = 1;
                    foreach (var row in Model.Organizations)
                    {
                        <tr style="border-bottom:1px solid #dee2e6;">
                            <td style="padding:6px 10px;">@i</td>
                            <td style="padding:6px 10px;font-weight:600;">@row.OrgName</td>
                            <td style="padding:6px 10px;">@row.PersonName</td>
                            <td style="padding:6px 10px;text-align:center;">
                                @if (row.Status == "Cleared")
                                {
                                    <span style="color:#28a745;font-weight:700;font-size:11px;">Cleared</span>
                                }
                                else if (row.Status == "Pending")
                                {
                                    <span style="color:#e37400;font-weight:700;font-size:11px;">Pending</span>
                                }
                                else
                                {
                                    <span style="color:#aaa;font-size:11px;">—</span>
                                }
                            </td>
                            <td style="padding:6px 10px;text-align:center;border-bottom:1px solid #333;min-width:100px;">
                                @if (row.Status == "Cleared" && !string.IsNullOrEmpty(row.SignatureBase64))
                                {
                                    <img src="@row.SignatureBase64"
                                         style="max-height:40px;max-width:90px;object-fit:contain;filter:invert(1);" />
                                }
                                else if (row.Status == "Cleared")
                                {
                                    <span style="color:#28a745;font-weight:700;">✔</span>
                                }
                                else
                                {
                                    @:&nbsp;
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="padding:20px;text-align:center;color:#888;font-style:italic;">
                            No organization signatories assigned yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div style="font-size:11px;color:#555;text-align:center;font-style:italic;margin-top:12px;">
            This clearance is valid for A.Y. @(Model?.AySemester ?? "the current semester") only.
            Cebu Technological University – Ginatilan Extension Campus · All rights reserved.
        </div>
    </div>
</div>

@section Styles {
<style>
    /* ── PERIOD SELECTOR ── */
    .period-selector-wrap { position:relative;display:inline-block; }
    .period-btn {
        display:flex;align-items:center;gap:10px;
        background:linear-gradient(135deg,#1a4731,#2d6a4f);
        border:none;border-radius:10px;padding:9px 16px;
        cursor:pointer;transition:filter 0.2s;user-select:none;min-width:280px;
    }
    .period-btn:hover { filter:brightness(1.12); }
    .period-btn-icon {
        width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.18);
        display:flex;align-items:center;justify-content:center;flex-shrink:0;color:white;font-size:14px;
    }
    .period-btn-text  { flex:1;text-align:left; }
    .period-btn-label { font-size:10px;color:rgba(255,255,255,0.6);margin-bottom:1px; }
    .period-btn-value { font-size:13px;font-weight:700;color:#fff;line-height:1.3; }
    .period-chevron   { color:rgba(255,255,255,0.7);font-size:11px;transition:transform 0.2s;flex-shrink:0; }
    .period-selector-wrap.open .period-chevron { transform:rotate(180deg); }

    .period-dd {
        display:none;position:absolute;top:calc(100% + 8px);left:0;
        min-width:300px;background:#fff;border:1px solid #e2e8f0;border-radius:12px;
        box-shadow:0 10px 36px rgba(0,0,0,0.18);z-index:999;
        padding:8px;flex-direction:column;gap:2px;max-height:320px;overflow-y:auto;
    }
    .period-selector-wrap.open .period-dd { display:flex; }
    .pd-opt {
        display:flex;align-items:center;justify-content:space-between;
        padding:9px 12px;border-radius:8px;font-size:13px;font-weight:600;
        color:#1a1a2e;cursor:pointer;transition:background 0.15s;gap:8px;
    }
    .pd-opt:hover    { background:rgba(0,0,0,0.04); }
    .pd-opt.selected { background:rgba(26,71,49,0.1);color:#1a4731; }
    .pd-opt.selected .pd-check { display:block; }
    .pd-check     { display:none;font-size:11px;color:#1a4731;flex-shrink:0; }
    .pd-opt-status { font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;flex-shrink:0; }
    .pd-opt-status.active    { background:rgba(72,187,120,0.15);color:#38a169; }
    .pd-opt-status.completed { background:rgba(160,174,192,0.15);color:#718096; }

    @@media print {
        .top-header, .sidebar,
        .d-flex.align-items-center.justify-content-between.mb-3 { display:none !important; }
        .main { padding:0 !important; }
        #pdf-preview { box-shadow:none;border-radius:0; }
        body { background:white; }
        .layout { display:block; }
    }
</style>
}

@section Scripts {
<script>
    const _serverPeriodId = @Model.ActivePeriodId;
    let allPeriods = [], selectedPeriodId = _serverPeriodId;

    async function loadPeriods() {
        const dd = document.getElementById('period-dd');
        try {
            const res  = await fetch('/api/student/periods');
            allPeriods = await res.json();
        } catch { allPeriods = []; }

        dd.innerHTML = '';
        if (!allPeriods.length) {
            dd.innerHTML = '<div style="padding:20px;text-align:center;font-size:12px;color:#888;">No academic periods found.</div>';
            return;
        }

        const preselected = allPeriods.find(p => p.id === _serverPeriodId)
                         ?? allPeriods.find(p => p.status === 'Active')
                         ?? allPeriods[0];
        selectedPeriodId = preselected.id;
        updatePeriodDisplay(preselected);

        allPeriods.forEach(p => {
            const opt     = document.createElement('div');
            opt.className = 'pd-opt' + (p.id === selectedPeriodId ? ' selected' : '');
            opt.dataset.id = p.id;
            opt.innerHTML = `
                <span style="flex:1;">A.Y. ${esc(p.ay)}, ${esc(p.sem)}</span>
                <span class="pd-opt-status ${p.status === 'Active' ? 'active' : 'completed'}">${esc(p.status)}</span>
                <i class="fas fa-check pd-check"></i>`;
            opt.onclick = (e) => { e.stopPropagation(); selectPeriod(p); };
            dd.appendChild(opt);
        });
    }

    function selectPeriod(p) {
        window.location.href = '/Student/DownloadPdf?periodId=' + p.id;
    }

    function updatePeriodDisplay(p) {
        document.getElementById('period-btn-value').textContent = `A.Y. ${p.ay}, ${p.sem}`;
    }

    function togglePeriodDd(e) { e.stopPropagation(); document.getElementById('period-wrap').classList.toggle('open'); }

    document.addEventListener('click', e => {
        const wrap = document.getElementById('period-wrap');
        if (wrap && !wrap.contains(e.target)) wrap.classList.remove('open');
    });

    function esc(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    loadPeriods();
</script>
}
